# ============================================================
# SokAlike007 Hacking AI — Environment Variables
# ============================================================
# Copy this file to `.env` (for local development with vercel dev)
# OR set these in your Vercel project dashboard:
#   Project → Settings → Environment Variables
# ============================================================

# REQUIRED: Your DevX Chat Model API authorization token
# Get this from the DevX API provider.
DEVX_API_KEY=your_devx_api_key_here

# OPTIONAL: Override the upstream API URL (defaults to the standard endpoint)
# DEVX_API_URL=https://devx-free-api.onrender.com/api/chatmodel

# OPTIONAL: Restrict CORS to a specific origin in production
# CORS_ORIGIN=https://yourdomain.com
